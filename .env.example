# --- Required: Google Jules ---
# Get an API key at https://jules.google.com/
JULES_API_KEY=

# Default Jules source for tasks that don't specify one.
# Format: sources/github/<owner>/<repo>
JULES_DEFAULT_SOURCE=

# Default starting branch for new sessions.
JULES_DEFAULT_BRANCH=main

# AUTO_CREATE_PR (default) or NONE
JULES_AUTO_MODE=AUTO_CREATE_PR


# --- Optional: LLM planner (only needed for `plan-tasks` and `auto` commands) ---
#
# The planner is fully OPTIONAL. Core commands (`dispatch`, `batch`, `wait`,
# `tail`, `status`, `mcp`, ...) work without any LLM key.
#
# Works with ANY OpenAI-compatible /chat/completions endpoint.
# Pick ONE provider and set base URL + model + key:
#
#   # OpenAI (the default — no LLM_BASE_URL needed)
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini
#
#   # OpenRouter (370+ models behind one API)
#   LLM_API_KEY=sk-or-...
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=openrouter/auto
#
#   # Ollama (local, free, no key required — set any non-empty value)
#   LLM_API_KEY=ollama
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=llama3.1
#
#   # vLLM / LiteLLM / Together / Groq / Fireworks / DeepInfra / Azure OpenAI ...
#   #   any service speaking the OpenAI Chat Completions schema works.
#
# OPENAI_API_KEY / OPENROUTER_API_KEY are also recognised as fallbacks.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
