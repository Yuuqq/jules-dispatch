# .env.example — copy to .env and fill in

JULES_API_KEY=your-api-key-here
JULES_DEFAULT_SOURCE=sources/github/YOU/your-repo
JULES_DEFAULT_BRANCH=main
JULES_AUTO_MODE=AUTO_CREATE_PR

# --- OpenRouter (optional, for `plan-tasks` / `auto` / MCP `jules_plan_tasks`) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Default: openrouter/auto (auto-routed). Other examples:
#   anthropic/claude-opus-4.7, openai/gpt-5.5-pro, google/gemini-pro-latest,
#   x-ai/grok-4.20, deepseek/deepseek-v4-pro, moonshotai/kimi-k2-thinking
OPENROUTER_MODEL=openrouter/auto
