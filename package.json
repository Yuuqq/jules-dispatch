{
  "name": "jules-dispatch",
  "version": "1.2.0",
  "description": "Batch dispatch to Google Jules + MCP server for Claude Code & Codex, with optional OpenAI-compatible task planning",
  "type": "module",
  "bin": {
    "jules-dispatch": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
